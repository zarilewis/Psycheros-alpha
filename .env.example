# Psycheros Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required: Z.ai API Configuration
# =============================================================================

# Your Z.ai API key (required)
ZAI_API_KEY=your-api-key-here

# =============================================================================
# Optional: Z.ai API Settings
# =============================================================================

# Base URL for the Z.ai API (default: https://api.z.ai/api/coding/paas/v4/chat/completions)
# ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4/chat/completions

# Model to use (default: glm-4.7)
# ZAI_MODEL=glm-4.7

# Worker model for lightweight tasks like auto-titling (default: GLM-4.5-Air)
# ZAI_WORKER_MODEL=GLM-4.5-Air

# =============================================================================
# Optional: Server Configuration
# =============================================================================

# Port to run the server on (default: 3000)
# PSYCHEROS_PORT=3000

# Host to bind to (default: 0.0.0.0)
# PSYCHEROS_HOST=0.0.0.0

# =============================================================================
# Optional: Appearance
# =============================================================================

# Primary accent color (default: #39ff14 phosphor green)
# Examples: #ff6b6b (coral), #4ecdc4 (teal), #ffb000 (amber), #00ffff (cyan)
# PSYCHEROS_ACCENT_COLOR=#39ff14

# =============================================================================
# Optional: Tool Access Control
# =============================================================================

# Comma-separated list of tools the entity is allowed to use.
# SECURITY: By default, no tools are enabled. You must explicitly enable tools.
#
# Available tools:
#   shell                      - Execute shell commands (powerful but potentially dangerous)
#   update_title               - Update the current conversation's title
#   create_significant_memory  - Create a permanent emotionally-significant memory
#   get_metrics                - Retrieve streaming performance metrics
#   sync_mcp                   - Manually sync with entity-core
#   append_to_self             - Tier 1: Add self-knowledge (append-only)
#   append_to_user             - Tier 1: Add user knowledge (append-only)
#   append_to_relationship     - Tier 1: Add relationship understanding (append-only)
#   maintain_identity          - Tier 2: Full identity file maintenance
#   list_identity_snapshots    - Tier 2: View available identity backups
#   graph_search_nodes         - Search knowledge graph nodes
#   graph_get_node             - Get a specific graph node by ID
#   graph_get_edges            - Get relationships from the graph
#   graph_traverse             - Traverse graph from a starting node
#   graph_get_subgraph         - Extract a subgraph centered on a node
#   graph_stats                - Get knowledge graph statistics
#
# Examples:
#   PSYCHEROS_TOOLS=update_title                        # Enable only title updates (safe)
#   PSYCHEROS_TOOLS=shell,update_title                  # Enable multiple tools
#   PSYCHEROS_TOOLS=shell,update_title,create_significant_memory
#   PSYCHEROS_TOOLS=                                    # No tools (default, safest)
#
# PSYCHEROS_TOOLS=update_title

# =============================================================================
# Optional: RAG (Retrieval-Augmented Generation) Configuration
# =============================================================================

# Enable RAG for memory retrieval (default: true)
# PSYCHEROS_RAG_ENABLED=true

# Maximum number of memory chunks to retrieve (default: 8)
# PSYCHEROS_RAG_MAX_CHUNKS=8

# Maximum token budget for retrieved content (default: 2000)
# PSYCHEROS_RAG_MAX_TOKENS=2000

# Minimum relevance score (0-1) for including memories (default: 0.3)
# PSYCHEROS_RAG_MIN_SCORE=0.3

# =============================================================================
# Optional: MCP Integration (entity-core)
# =============================================================================

# Enable connection to entity-core MCP server (default: false)
# PSYCHEROS_MCP_ENABLED=false

# Command to spawn entity-core (default: /home/zari/.deno/bin/deno)
# PSYCHEROS_MCP_COMMAND=/home/zari/.deno/bin/deno

# Arguments for entity-core (default: run -A ~/projects/entity-core/src/mod.ts)
# PSYCHEROS_MCP_ARGS=run -A /home/zari/projects/entity-core/src/mod.ts

# Instance ID for this embodiment (default: psycheros-harness)
# PSYCHEROS_MCP_INSTANCE=psycheros-harness

# Data directory for entity-core (default: ~/projects/entity-core/data)
# PSYCHEROS_ENTITY_CORE_DATA_DIR=/home/zari/projects/entity-core/data

# =============================================================================
# Optional: Timezone
# =============================================================================

# Timezone for message timestamps and cron scheduling (default: UTC)
# Examples: America/Los_Angeles, America/New_York, Europe/London
# TZ=UTC

# =============================================================================
# Optional: Memory System
# =============================================================================

# Hour to run daily summarization (default: 4, meaning 4 AM)
# PSYCHEROS_MEMORY_HOUR=4

# =============================================================================
# Optional: Snapshot System
# =============================================================================

# Hour to run daily identity snapshots (default: 3, meaning 3 AM)
# PSYCHEROS_SNAPSHOT_HOUR=3

# Number of days to retain snapshots before cleanup (default: 30)
# PSYCHEROS_SNAPSHOT_RETENTION_DAYS=30
