{
  "name": "@sby/daemon",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run --watch -A --unstable-cron src/main.ts",
    "start": "deno run -A --unstable-cron src/main.ts",
    "stop": "pkill -INT -f 'deno.*main.ts' || true"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1",
    "@std/async": "jsr:@std/async@^1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "@db/sqlite": "jsr:@db/sqlite@^0.12",
    "@xenova/transformers": "npm:@huggingface/transformers@3.3.1"
  },
  "lint": {
    "exclude": ["web/lib/"]
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  }
}
