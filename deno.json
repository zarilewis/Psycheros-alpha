{
  "name": "@sby/daemon",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run --watch --allow-read --allow-write --allow-net --allow-env --allow-ffi --allow-run src/main.ts",
    "start": "deno run --allow-read --allow-write --allow-net --allow-env --allow-ffi --allow-run src/main.ts"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1",
    "@std/async": "jsr:@std/async@^1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "@db/sqlite": "jsr:@db/sqlite@^0.12"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  }
}
