{
  "name": "@psycheros/daemon",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run --watch -A --unstable-cron src/main.ts",
    "start": "deno run -A --unstable-cron src/main.ts",
    "stop": "pkill -INT -f 'deno.*main.ts' || true"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1",
    "@std/async": "jsr:@std/async@^1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@db/sqlite": "jsr:@db/sqlite@^0.12",
    "@xenova/transformers": "npm:@huggingface/transformers@3.3.1",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1",
    "marked": "npm:marked@^15",
    "dompurify": "npm:dompurify@^3",
    "jsdom": "npm:jsdom@^26",
    "pdf-parse": "npm:pdf-parse@^1.1.1",
    "mammoth": "npm:mammoth@^1.8.0",
    "xlsx": "npm:xlsx@^0.18.5",
    "web-push": "npm:web-push@^3.6",
    "jszip": "npm:jszip@^3",
    "@zendrex/buttplug.js": "npm:@zendrex/buttplug.js@^0.3"
  },
  "lint": {
    "exclude": ["web/lib/", "web/js/"]
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  }
}
